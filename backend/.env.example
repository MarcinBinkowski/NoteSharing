# General
NOTES_APP_NAME="Notes"
NOTES_DEBUG=true
NOTES_ENABLE_DOCS_IN_PROD=false

# Database backend: "sqlite" | "firestore"
NOTES_DATABASE_BACKEND=sqlite

# SQLite (used when DATABASE_BACKEND=sqlite)
NOTES_SQLITE_URL=sqlite+aiosqlite:///./data/notes.db

# Firestore (used when DATABASE_BACKEND=firestore)
NOTES_GCP_PROJECT_ID=
NOTES_FIRESTORE_DATABASE=(default)

# Security / JWT
NOTES_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
NOTES_SESSION_SECRET_KEY=change-me-too-use-openssl-rand-hex-32
NOTES_JWT_ALGORITHM=HS256
NOTES_JWT_ACCESS_EXPIRE_MINUTES=15
NOTES_JWT_REFRESH_EXPIRE_DAYS=7

# Google OAuth
NOTES_GOOGLE_CLIENT_ID=
NOTES_GOOGLE_CLIENT_SECRET=
NOTES_BACKEND_URL=http://localhost:8000
NOTES_FRONTEND_URL=http://localhost:5173

# CORS
NOTES_CORS_ORIGINS=["http://localhost:5173"]

# Rate limiting
# Format: "<count>/<period>" e.g. "60/minute", "1000/hour"
NOTES_RATE_LIMIT_DEFAULT=60/minute

# Logging
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
NOTES_LOG_LEVEL=INFO
