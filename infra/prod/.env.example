TF_VAR_project_id=your-gcp-prod-project-id
TF_VAR_google_oauth_client_id=xxxxxxxxxxxx.apps.googleusercontent.com
TF_VAR_google_oauth_client_secret=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
TF_VAR_jwt_secret_key=  # openssl rand -hex 32
TF_VAR_session_secret_key=  # openssl rand -hex 32

# Optional overrides (uncomment to change from defaults)
# TF_VAR_min_instance_count=1
# TF_VAR_max_instance_count=5
# TF_VAR_memory_limit=512Mi
